<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:id="@+id/activity_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:background="@drawable/goal_card_default">

        <!-- Text column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="16dp">

            <TextView
                android:id="@+id/activity_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:fontFamily="@font/space_bold"
                tools:text="Mostly Sedentary"
                xmlns:tools="http://schemas.android.com/tools"/>

            <TextView
                android:id="@+id/activity_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginTop="5dp"
                android:lineSpacingMultiplier="1.3"
                tools:text="Most of the day sitting — office work, studying, desk job."
                xmlns:tools="http://schemas.android.com/tools"/>

        </LinearLayout>

        <!-- Radio circle -->
        <View
            android:id="@+id/activity_radio"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/radio_default"/>

    </LinearLayout>

</FrameLayout>