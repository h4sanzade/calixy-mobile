<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#171717"
    tools:context="com.hasanzade.SetupProfileFirstFragment">

  <androidx.constraintlayout.widget.Guideline
      android:id="@+id/guideline_top"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      app:layout_constraintGuide_percent="0.04"/>

  <androidx.constraintlayout.widget.Guideline
      android:id="@+id/guideline_bottom"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      app:layout_constraintGuide_percent="0.92"/>

  <androidx.constraintlayout.widget.Guideline
      android:id="@+id/guideline_start"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      app:layout_constraintGuide_percent="0.06"/>

  <androidx.constraintlayout.widget.Guideline
      android:id="@+id/guideline_end"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      app:layout_constraintGuide_percent="0.94"/>

  <ImageButton
      android:id="@+id/back_button"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:src="@drawable/back_button"
      android:background="#171717"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/guideline_top"
      android:layout_marginStart="10dp"/>

  <com.google.android.material.textview.MaterialTextView
      android:id="@+id/complete_profile_tv"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:fontFamily="@font/space_bold"
      android:text="Complete your profile"
      android:textSize="20sp"
      android:textColor="@color/white"
      android:gravity="center"
      app:layout_constraintEnd_toStartOf="@id/guideline_end"
      app:layout_constraintStart_toEndOf="@id/guideline_start"
      app:layout_constraintTop_toBottomOf="@id/guideline_top"
      android:layout_marginTop="8dp"/>

  <TextView
      android:id="@+id/complete_profile_about_tv"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:text="Finish setting up your profile in four quick steps and start tracking your calories today."
      android:textColor="#B2B2B2"
      android:textSize="13sp"
      android:gravity="center"
      app:layout_constraintEnd_toStartOf="@id/guideline_end"
      app:layout_constraintStart_toEndOf="@id/guideline_start"
      app:layout_constraintTop_toBottomOf="@id/complete_profile_tv"
      android:layout_marginTop="8dp"/>

  <include
      android:id="@+id/view_step_progress_id"
      layout="@layout/view_step_progress"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@id/complete_profile_about_tv"
      app:layout_constraintStart_toEndOf="@id/guideline_start"
      app:layout_constraintEnd_toStartOf="@id/guideline_end"
      android:layout_marginTop="20dp"/>

  <TextView
      android:id="@+id/user_profile"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:text="Fill your information"
      android:textColor="@color/white"
      android:fontFamily="@font/space_medium"
      android:textSize="16sp"
      android:gravity="center"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/view_step_progress_id"
      android:layout_marginTop="20dp"/>

  <ImageView
      android:id="@+id/user_profile_image"
      android:layout_width="0dp"
      android:layout_height="0dp"
      android:src="@drawable/user_profile"
      android:contentDescription="User profile image"
      android:layout_marginTop="10dp"
      app:layout_constraintTop_toBottomOf="@id/user_profile"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintWidth_percent="0.25"
      app:layout_constraintDimensionRatio="1:1"/>

  <TextView
      android:id="@+id/add_profile_pict_info"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="Add profile picture"
      android:textColor="@color/white"
      android:fontFamily="@font/space_regular"
      android:textSize="12sp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/user_profile_image"
      android:layout_marginTop="4dp"/>

  <com.google.android.material.textfield.TextInputLayout
      android:id="@+id/first_name_et"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:hint="First Name"
      app:boxStrokeColor="#E6E5E5"
      app:boxBackgroundMode="outline"
      app:boxBackgroundColor="#171717"
      android:textColorHint="#888888"
      app:layout_constraintTop_toBottomOf="@id/add_profile_pict_info"
      app:layout_constraintStart_toEndOf="@id/guideline_start"
      app:layout_constraintEnd_toStartOf="@id/last_name_et"
      android:layout_marginTop="16dp"
      android:layout_marginEnd="6dp"
      app:layout_constraintWidth_percent="0.44"
      app:layout_constraintHorizontal_chainStyle="spread_inside"
      app:hintTextColor="#888888">

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/first_name_edit_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:singleLine="true"/>
  </com.google.android.material.textfield.TextInputLayout>

  <com.google.android.material.textfield.TextInputLayout
      android:id="@+id/last_name_et"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:hint="Last Name"
      app:boxStrokeColor="#E6E5E5"
      app:boxBackgroundMode="outline"
      app:boxBackgroundColor="#171717"
      android:textColorHint="#888888"
      app:layout_constraintTop_toBottomOf="@id/add_profile_pict_info"
      app:layout_constraintStart_toEndOf="@id/first_name_et"
      app:layout_constraintEnd_toStartOf="@id/guideline_end"
      android:layout_marginTop="16dp"
      android:layout_marginStart="6dp"
      app:layout_constraintWidth_percent="0.44"
      app:hintTextColor="#888888">

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/last_name_edit_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:singleLine="true"/>
  </com.google.android.material.textfield.TextInputLayout>

  <com.google.android.material.textfield.TextInputLayout
      android:id="@+id/gender_input_layout"
      style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:hint="Gender"
      app:boxStrokeColor="#E6E5E5"
      app:boxBackgroundColor="#171717"
      android:textColorHint="#888888"
      app:hintTextColor="#888888"
      app:layout_constraintTop_toBottomOf="@id/first_name_et"
      app:layout_constraintStart_toEndOf="@id/guideline_start"
      app:layout_constraintEnd_toStartOf="@id/guideline_end"
      android:layout_marginTop="10dp">

    <AutoCompleteTextView
        android:id="@+id/gender_auto_complete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:inputType="none"
        android:focusable="false"
        android:cursorVisible="false"
        android:dropDownHeight="wrap_content"/>
  </com.google.android.material.textfield.TextInputLayout>

  <TextView
      android:id="@+id/dob_label"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:text="Date of Birth"
      android:textColor="#888888"
      android:textSize="13sp"
      app:layout_constraintTop_toBottomOf="@id/gender_input_layout"
      app:layout_constraintStart_toEndOf="@id/guideline_start"
      app:layout_constraintEnd_toStartOf="@id/guideline_end"
      android:layout_marginTop="14dp"/>

  <androidx.cardview.widget.CardView
      android:id="@+id/dob_card"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      app:cardBackgroundColor="#2A2A2A"
      app:cardCornerRadius="14dp"
      app:cardElevation="0dp"
      app:layout_constraintTop_toBottomOf="@id/dob_label"
      app:layout_constraintStart_toEndOf="@id/guideline_start"
      app:layout_constraintEnd_toStartOf="@id/guideline_end">

    <LinearLayout
        android:id="@+id/calendar_layout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

      <ImageView
          android:id="@+id/dob_icon"
          android:layout_width="22dp"
          android:layout_height="22dp"
          android:contentDescription="Calendar icon"
          android:src="@drawable/calendar_icon"
          app:tint="#888888"/>

      <TextView
          android:id="@+id/dob_text"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_marginStart="12dp"
          android:layout_weight="1"
          android:text="DD/MM/YYYY"
          android:textColor="#888888"
          android:textSize="15sp"/>

    </LinearLayout>
  </androidx.cardview.widget.CardView>

  <com.google.android.material.button.MaterialButton
      android:id="@+id/next_button"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginEnd="20dp"
      android:backgroundTint="#FF5A16"
      android:fontFamily="@font/space_medium"
      android:text="Next"
      app:cornerRadius="8dp"
      android:textColor="@color/white"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintBottom_toBottomOf="@id/guideline_bottom"
      app:layout_constraintWidth_percent="0.40"/>

</androidx.constraintlayout.widget.ConstraintLayout>