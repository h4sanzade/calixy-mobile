<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context="com.hasanzade.SetupProfileFirstFragment"
    android:background="#171717">

  <ImageButton
      android:id="@+id/back_button"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:src="@drawable/back_button"
      android:background="#171717"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      android:layout_marginTop="20dp"
      android:layout_marginStart="10dp"/>

  <com.google.android.material.textview.MaterialTextView
      android:id="@+id/complete_profile_tv"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:fontFamily="@font/space_bold"
      android:text="Complete your profile"
      android:textSize="20sp"
      android:textColor="@color/white"
      android:gravity="center"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      android:layout_marginTop="33dp"
      android:layout_marginEnd="50dp"
      android:layout_marginStart="50dp"/>

  <!-- Subtitle -->
  <TextView
      android:id="@+id/complete_profile_about_tv"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:text="Finish setting up your profile in four quick steps and start tracking your calories today."
      android:textColor="#B2B2B2"
      android:textSize="13sp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/complete_profile_tv"
      android:layout_marginEnd="50dp"
      android:layout_marginStart="50dp"
      android:gravity="center"
      android:layout_marginTop="10dp"/>

  <!-- Step Progress -->
  <include
      android:id="@+id/view_step_progress_id"
      layout="@layout/view_step_progress"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginStart="50dp"
      android:layout_marginEnd="50dp"
      android:layout_marginTop="25dp"
      app:layout_constraintTop_toBottomOf="@id/complete_profile_about_tv"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"/>

  <TextView
      android:id="@+id/user_profile"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:text="Fill your information"
      android:textColor="@color/white"
      android:fontFamily="@font/space_medium"
      android:textSize="16sp"
      android:gravity="center"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/view_step_progress_id"
      android:layout_marginTop="25dp"
      android:layout_marginStart="16dp"
      android:layout_marginEnd="16dp"/>

  <ImageView
      android:id="@+id/user_profile_image"
      android:layout_width="0dp"
      android:layout_height="0dp"
      android:src="@drawable/user_profile"
      android:contentDescription="User profile image"
      android:layout_marginTop="10dp"
      app:layout_constraintTop_toBottomOf="@id/user_profile"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintWidth_percent="0.28"
      app:layout_constraintDimensionRatio="1:1"/>

  <TextView
      android:id="@+id/add_profile_pict_info"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="Add profile picture"
      android:textColor="@color/white"
      android:fontFamily="@font/space_regular"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/user_profile_image"
      android:layout_marginTop="3dp"/>

  <com.google.android.material.textfield.TextInputLayout
      android:id="@+id/first_name_et"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:hint="First Name"
      app:boxStrokeColor="#E6E5E5"
      app:boxBackgroundMode="outline"
      android:padding="8dp"
      android:textColorHint="@color/white"
      app:layout_constraintTop_toBottomOf="@id/add_profile_pict_info"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toStartOf="@id/last_name_et"
      android:layout_marginTop="20dp"
      android:layout_marginStart="20dp"
      android:layout_marginEnd="4dp"
      app:layout_constraintHorizontal_chainStyle="spread"
      app:layout_constraintWidth_percent="0.46">

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/first_name_edit_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:singleLine="true"/>
  </com.google.android.material.textfield.TextInputLayout>

  <com.google.android.material.textfield.TextInputLayout
      android:id="@+id/last_name_et"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:hint="Last Name"
      app:boxStrokeColor="#E6E5E5"
      app:boxBackgroundMode="outline"
      android:padding="8dp"
      android:textColorHint="@color/white"
      app:layout_constraintTop_toBottomOf="@id/add_profile_pict_info"
      app:layout_constraintStart_toEndOf="@id/first_name_et"
      app:layout_constraintEnd_toEndOf="parent"
      android:layout_marginTop="20dp"
      android:layout_marginStart="4dp"
      android:layout_marginEnd="20dp"
      app:layout_constraintWidth_percent="0.46">

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/last_name_edit_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:singleLine="true"/>
  </com.google.android.material.textfield.TextInputLayout>

  <com.google.android.material.textfield.TextInputLayout
      android:id="@+id/gender_input_layout"
      style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:hint="Gender"
      app:boxStrokeColor="#E6E5E5"
      app:boxBackgroundColor="#171717"
      android:padding="8dp"
      android:textColorHint="@color/white"
      app:layout_constraintTop_toBottomOf="@id/first_name_et"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      android:layout_marginTop="2dp"
      android:layout_marginStart="20dp"
      android:layout_marginEnd="0dp"
      app:layout_constraintWidth_percent="0.48"
      app:layout_constraintHorizontal_bias="0">

    <AutoCompleteTextView
        android:id="@+id/gender_auto_complete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:inputType="none"
        android:focusable="false"
        android:cursorVisible="false"
        android:dropDownHeight="wrap_content"/>
  </com.google.android.material.textfield.TextInputLayout>

  <TextView
      android:id="@+id/dob_label"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:text="Select Date of Birth"
      android:textColor="@color/white"
      android:textSize="14sp"
      app:layout_constraintTop_toBottomOf="@id/gender_input_layout"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      android:layout_marginTop="16dp"
      android:layout_marginStart="20dp"
      android:layout_marginEnd="20dp"/>

  <androidx.cardview.widget.CardView
      android:id="@+id/dob_card"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginStart="20dp"
      android:layout_marginTop="8dp"
      android:layout_marginEnd="20dp"
      app:cardBackgroundColor="#2A2A2A"
      app:cardCornerRadius="14dp"
      app:cardElevation="0dp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/dob_label">

    <LinearLayout
        android:id="@+id/calendar_layout"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

      <ImageView
          android:id="@+id/dob_icon"
          android:layout_width="26dp"
          android:layout_height="26dp"
          android:contentDescription="Calendar icon"
          android:src="@drawable/calendar_icon"
          app:tint="#888888"/>

      <TextView
          android:id="@+id/dob_text"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_marginStart="14dp"
          android:layout_weight="1"
          android:text="DD/MM/YYYY"
          android:textColor="#888888"
          android:textSize="16sp"/>

    </LinearLayout>
  </androidx.cardview.widget.CardView>

  <com.google.android.material.button.MaterialButton
      android:id="@+id/next_button"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:layout_marginEnd="20dp"
      android:layout_marginBottom="16dp"
      android:backgroundTint="#121212"
      android:fontFamily="@font/space_medium"
      android:text="Next"
      app:cornerRadius="14dp"
      android:textColor="@color/white"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintTop_toBottomOf="@id/dob_card"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintVertical_bias="0"
      app:layout_constraintWidth_percent="0.40"/>

</androidx.constraintlayout.widget.ConstraintLayout>