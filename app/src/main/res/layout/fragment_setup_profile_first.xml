<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context="com.hasanzade.SetupProfileFirstFragment"
    android:background="#171717">

  <View
      android:id="@+id/line_1_2"
      android:layout_width="0dp"
      android:layout_height="2dp"
      android:background="@drawable/dashed_line_active"
      app:layout_constraintStart_toEndOf="@id/step1"
      app:layout_constraintTop_toTopOf="@id/step1"
      app:layout_constraintBottom_toBottomOf="@id/step1"/>


  <com.google.android.material.textview.MaterialTextView
      android:id="@+id/complete_profile_tv"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:fontFamily="@font/space_bold"
      android:text="Complete your profile"
      android:textSize="20sp"
      android:textColor="@color/white"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      android:layout_marginTop="33dp"
      android:layout_marginEnd="50dp"
      android:layout_marginStart="50dp">

  </com.google.android.material.textview.MaterialTextView>

  <TextView
      android:id="@+id/complete_profile_about_tv"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:text="Finish setting up your profile in four quick steps and start tracking your calories today."
      android:textColor="#B2B2B2"
      android:textSize="13sp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/complete_profile_tv"
      android:layout_marginEnd="50dp"
      android:layout_marginStart="50dp"
      android:gravity="center"
      android:layout_marginTop="10dp">
  </TextView>

  <include
      android:id="@+id/view_step_progress_id"
      layout="@layout/view_step_progress"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginStart="50dp"
      android:layout_marginEnd="50dp"
      android:layout_marginTop="25dp"
      app:layout_constraintTop_toBottomOf="@id/complete_profile_about_tv"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"/>


  <TextView
      android:id="@+id/user_profile"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:text="Fill your information"
      android:textColor="@color/white"
      android:fontFamily="@font/space_medium"
      android:textSize="16sp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/view_step_progress_id"
      android:layout_marginTop="50dp"
      android:layout_marginStart="122dp"
      android:layout_marginEnd="123dp"
      android:gravity="center">

  </TextView>

  <ImageView
      android:id="@+id/user_profile_image"
      android:layout_width="0dp"
      android:layout_height="0dp"
      android:src="@drawable/user_profile"
      android:contentDescription="User profile image"
      android:layout_marginTop="16dp"
      app:layout_constraintTop_toBottomOf="@id/user_profile"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintWidth_percent="0.3"
      app:layout_constraintDimensionRatio="1:1"/>

  <TextView
      android:id="@+id/add_profile_pict_info"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="Add profile picture"
      android:textColor="@color/white"
      android:fontFamily="@font/space_regular"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/user_profile_image"
      android:layout_marginTop="3dp">

  </TextView>

  <com.google.android.material.textfield.TextInputLayout
      android:id="@+id/first_name_et"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:hint="First Name"
      app:boxStrokeColor="#E6E5E5"
      app:boxBackgroundMode="outline"
      android:padding="8dp"
      android:textColorHint="@color/white"
      app:layout_constraintTop_toBottomOf="@id/add_profile_pict_info"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toStartOf="@id/last_name_et"
      android:layout_marginTop="20dp"
      android:layout_marginEnd="10dp"
      app:layout_constraintWidth_percent="0.48">

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/first_name_edit_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:singleLine="true" />
  </com.google.android.material.textfield.TextInputLayout>

  <com.google.android.material.textfield.TextInputLayout
      android:id="@+id/last_name_et"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:hint="Last Name"
      app:boxStrokeColor="#E6E5E5"
      app:boxBackgroundMode="outline"
      android:padding="8dp"
      android:textColorHint="@color/white"
      app:layout_constraintTop_toBottomOf="@id/add_profile_pict_info"
      app:layout_constraintStart_toEndOf="@id/first_name_et"
      app:layout_constraintEnd_toEndOf="parent"
      android:layout_marginTop="20dp"
      android:layout_marginStart="7dp"
      android:layout_marginEnd="20dp"
      app:layout_constraintWidth_percent="0.48">

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/last_name_edit_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:singleLine="true" />
  </com.google.android.material.textfield.TextInputLayout>








</androidx.constraintlayout.widget.ConstraintLayout>