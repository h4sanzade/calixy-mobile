<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <View
        android:id="@+id/line"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#2E2E2E"
        app:layout_constraintStart_toStartOf="@id/step1"
        app:layout_constraintEnd_toEndOf="@id/step4"
        app:layout_constraintTop_toTopOf="@id/step1"
        app:layout_constraintBottom_toBottomOf="@id/step1"/>

    <TextView
        android:id="@+id/step1"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="1"
        android:textColor="@color/white"
        android:gravity="center"
        android:background="@drawable/step_active_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/step2"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="2"
        android:gravity="center"
        android:textColor="#A0A0A0"
        android:background="@drawable/step_inactive_bg"
        app:layout_constraintStart_toEndOf="@id/step1"
        app:layout_constraintEnd_toStartOf="@id/step3"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/step3"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="3"
        android:gravity="center"
        android:textColor="#A0A0A0"
        android:background="@drawable/step_inactive_bg"
        app:layout_constraintStart_toEndOf="@id/step2"
        app:layout_constraintEnd_toStartOf="@id/step4"

        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/step4"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="4"
        android:gravity="center"
        android:textColor="#A0A0A0"
        android:background="@drawable/step_inactive_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>